{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "website",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-03-12",
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"secrets": {
		"required": [
			"LASTFM_API_KEY"
		]
	},
	"observability": {
		"logs": {
			"enabled": true
		},
		"traces": {
			"enabled": true
		}
	},
	"preview_urls": false,
	"send_metrics": false,
	"upload_source_maps": true,
	"workers_dev": false
}
